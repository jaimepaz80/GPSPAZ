{
  "version": 2,
  "builds": [
    {
      "src": "API/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/API/(.*)",
      "dest": "API/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}

